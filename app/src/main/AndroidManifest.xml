<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tienda.abarrotes">

    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AbarrotesApp">

        <activity android:name=".ui.common.ScannerActivity" />
        <activity android:name=".ui.common.QRTrabajadorActivity" />

        <activity android:name=".ui.cajero.ResumenVentasActivity" />
        <activity android:name=".ui.cajero.CerrarCajaActivity" />
        <activity android:name=".ui.cajero.AbrirCajaActivity" />
        <activity android:name=".ui.cajero.POSVentaActivity" />
        <activity android:name=".ui.cajero.CajeroDashboardActivity" />

        <activity android:name=".ui.reponedor.HistorialReposicionActivity" />
        <activity android:name=".ui.reponedor.ReposicionActivity" />
        <activity android:name=".ui.reponedor.ReponedorDashboardActivity" />

        <activity android:name=".ui.admin.inventario.MovimientosStockActivity" />
        <activity android:name=".ui.admin.inventario.IngresoMercaderiaActivity" />

        <activity android:name=".ui.admin.productos.DetalleProductoActivity" />
        <activity android:name=".ui.admin.productos.EditarProductoActivity" />
        <activity android:name=".ui.admin.productos.RegistrarProductoActivity" />

        <activity android:name=".ui.admin.trabajadores.EditarTrabajadorActivity" />
        <activity android:name=".ui.admin.trabajadores.RegistrarTrabajadorActivity" />

        <activity android:name=".ui.admin.AdminDashboardActivity" />

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>