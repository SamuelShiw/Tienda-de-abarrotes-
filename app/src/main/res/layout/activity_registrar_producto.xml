<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrar producto"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_xxl"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNombreProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:hint="Nombre del producto" />

        <EditText
            android:id="@+id/etCategoriaProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Categoría" />

        <EditText
            android:id="@+id/etMarcaProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Marca" />

        <EditText
            android:id="@+id/etUnidadProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Unidad de medida" />

        <EditText
            android:id="@+id/etPrecioCompraProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Precio de compra"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etPrecioVentaProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Precio de venta"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etStockMinimoProducto"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Stock mínimo"
            android:inputType="number" />

        <Button
            android:id="@+id/btnGuardarProducto"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:text="Guardar producto" />

        <Button
            android:id="@+id/btnCancelarProducto"
            style="@style/ButtonSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="Cancelar" />

    </LinearLayout>

</ScrollView>