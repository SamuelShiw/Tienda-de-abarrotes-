<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar trabajador"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_xxl"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNombresEditarTrabajador"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:hint="Nombres" />

        <EditText
            android:id="@+id/etApellidosEditarTrabajador"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Apellidos" />

        <EditText
            android:id="@+id/etDniEditarTrabajador"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="DNI"
            android:inputType="number" />

        <EditText
            android:id="@+id/etTelefonoEditarTrabajador"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Teléfono"
            android:inputType="phone" />

        <EditText
            android:id="@+id/etUsuarioEditarTrabajador"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Usuario" />

        <EditText
            android:id="@+id/etContrasenaEditarTrabajador"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:hint="Nueva contraseña opcional"
            android:inputType="textPassword" />

        <Spinner
            android:id="@+id/spRolEditarTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:background="@drawable/bg_input"
            android:padding="@dimen/space_16" />

        <Spinner
            android:id="@+id/spEstadoEditarTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:background="@drawable/bg_input"
            android:padding="@dimen/space_16" />

        <Button
            android:id="@+id/btnActualizarTrabajador"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:text="Actualizar trabajador" />

        <Button
            android:id="@+id/btnCancelarEditarTrabajador"
            style="@style/ButtonSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="Cancelar" />

    </LinearLayout>

</ScrollView>