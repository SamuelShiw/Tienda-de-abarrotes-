<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="@dimen/space_16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvItemNombreProducto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Arroz Extra"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemEstadoProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="72dp"
            android:gravity="center"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_8"
            android:text="ACTIVO"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvItemCodigoProducto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="PROD-0001"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <TextView
        android:id="@+id/tvItemCategoriaProducto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="Categoría: Abarrotes"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <TextView
        android:id="@+id/tvItemPrecioProducto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="S/ 6.50"
        android:textColor="@color/ios_primary"
        android:textSize="@dimen/text_md"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvItemStocksProducto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="Almacén: 0 | Tienda: 0"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnDetalleProducto"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="Detalle"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_info_details"
            android:tint="@color/ios_primary" />

        <ImageButton
            android:id="@+id/btnEditarProducto"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="@dimen/space_8"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="Editar"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/ios_primary" />

        <ImageButton
            android:id="@+id/btnDesactivarProducto"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="@dimen/space_8"
            android:background="@drawable/bg_button_danger"
            android:contentDescription="Desactivar"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/ios_text_white" />
    </LinearLayout>

</LinearLayout>