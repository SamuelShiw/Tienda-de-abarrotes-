<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="@dimen/space_16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvItemNombreTrabajador"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Juan Pérez"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemEstadoTrabajador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="72dp"
            android:gravity="center"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_8"
            android:text="ACTIVO"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvItemDniTrabajador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="DNI: 12345678"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <TextView
        android:id="@+id/tvItemUsuarioTrabajador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="Usuario: juan"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <TextView
        android:id="@+id/tvItemRolTrabajador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="Rol: CAJERO"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <TextView
        android:id="@+id/tvItemTelefonoTrabajador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="Teléfono: 999999999"
        android:textColor="@color/ios_text_secondary"
        android:textSize="@dimen/text_sm" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnQrTrabajador"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="QR"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_share"
            app:tint="@color/ios_primary" />

        <ImageButton
            android:id="@+id/btnEditarTrabajador"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="@dimen/space_8"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="Editar"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/ios_primary" />

        <ImageButton
            android:id="@+id/btnDesactivarTrabajador"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="@dimen/space_8"
            android:background="@drawable/bg_button_danger"
            android:contentDescription="Desactivar"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/ios_text_white" />
    </LinearLayout>

</LinearLayout>