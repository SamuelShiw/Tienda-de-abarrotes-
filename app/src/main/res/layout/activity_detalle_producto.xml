<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_24">

        <TextView
            android:id="@+id/tvDetalleNombreProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textColor="@color/ios_text_primary"
            android:textSize="@dimen/text_xxl"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetalleCodigoProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleCodigoBarrasProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <ImageView
            android:id="@+id/ivDetalleBarcodeProducto"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="@dimen/space_16"
            android:adjustViewBounds="true"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_12"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvDetalleCategoriaProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleMarcaProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleUnidadProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetallePrecioCompraProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetallePrecioVentaProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleStockAlmacenProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleStockTiendaProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleStockMinimoProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleEstadoProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvDetalleFechaProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:textColor="@color/ios_text_secondary"
            android:textSize="@dimen/text_md" />

    </LinearLayout>

</ScrollView>